flowchart TD

%% Safe Agent - main diagram (mirrors ReActHook.mmd structure)
%% Amber nodes = our middleware implementations. See linked .mmd files for detail.

    A([Session Open]) --> H_CS

    subgraph MEMORY_GROUP ["Memory"]
        direction TB
        STORE[(store  see Memory.mmd)]
        STORE_VEC[(store_vec  see Memory.mmd)]
        CLEANROOM_MEM[(cleanroom  see Cleanroom.mmd)]
        STORE ~~~ STORE_VEC ~~~ CLEANROOM_MEM
    end

    STORE -. "session history" .-> H_CS
    STORE_VEC -. "intent patterns" .-> H_CS
    CLEANROOM_MEM -. "ensemble wisdom" .-> H_CS
    STORE_VEC -. "context inject before_model" .-> SEED
    STORE_VEC -. "asearch" .-> H_RS
    H_AF -. "write store_raw" .-> STORE
    H_AF -. "write store_vec" .-> STORE_VEC
    H_CE -. "GCT nomination" .-> CLEANROOM_MEM

    subgraph AGENT_CHAIN ["Agent Chain"]
        H_CS(["GCI · session_init  see GCI.mmd"])
        H_CS --> SEED["PromptComposer  see PromptComposer.mmd"]

        SEED --> H_CMS

        subgraph LLM_LOOP ["LLM Reasoning Loop"]
            H_CMS(["EntryScopeGuard · Routing  pre_model_hook  see EntryScopeGuard.mmd"])
            H_CMS --> H_PG
            H_PG(["HITLPlanMiddleware · before_model  see HITLMiddleware.mmd"])
            H_PG --> LLM{claude-sonnet-4-6  adaptive thinking}

            LLM -->|stream chunk| H_TOK(["AG-UI  on_llm_new_token"])
            H_TOK --> LLM

            LLM --> H_LE(["OutputGuard · after_model  see OutputGuard.mmd"])
            LLM --> H_LERR(["LLM error"])

            H_LE --> H_TXT(["reasoning output  thinking blocks"])
            H_TXT --> DECIDE{tool_use block?}
        end

        subgraph TOOL_EXEC ["Tool Execution"]
            H_AA(["HopSanitizer · pre_tool_hook  see HopSanitizer.mmd"])
            H_HITL(["HITLMiddleware · awrap_tool_call  see HITLMiddleware.mmd"])
            H_TS(["MCPTool.ainvoke"])
            TOOL[MCPTool._arun  graphy-query-mcp to Neo4j]
            H_TE(["ReScopeGuard · post_tool_hook  see ReScopeGuard.mmd"])
            H_TERR(["tool error"])

            H_AA --> H_HITL
            H_HITL --> H_TS
            H_TS --> TOOL

            subgraph RETRIEVER ["Memory Retriever  if tool uses RAG"]
                H_RS(["store_vec.asearch  see MemRetriever.mmd"])
                RETRIEVE[Bedrock Titan embed + HNSW cosine search]
                H_RE(["context retrieved"])
                H_RERR(["retriever error"])
                H_RS --> RETRIEVE --> H_RE
                RETRIEVE --> H_RERR
            end

            TOOL --> H_RS
            H_RE --> H_TE
            H_RERR --> H_TERR
        end

        DECIDE -->|Yes| H_AA
        H_TE --> HISTORY[LangGraph state update  Postgres checkpoint write]
        H_TERR --> HISTORY
        HISTORY --> H_CMS

        DECIDE -->|No - Final Answer| H_AF
        H_AF(["MemMiddleware · after_model  see MemMiddleware.mmd"])
        H_AF --> H_CE(["GCT · session_close  see GCT.mmd"])
        H_LERR --> H_CERR(["chain error"])
    end

    H_CE --> OUT([Response to User])
    H_CERR --> OUT

